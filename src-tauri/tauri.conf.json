{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "微探",
  "version": "0.3.0",
  "identifier": "ai.lovstudio.wxmp-cracker",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:4382",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "微探 - Powered by Lovstudio",
        "width": 1400,
        "height": 918,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist"
    },
    "externalBin": [
      "binaries/wcx"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxMjZCMkE0RjE4RjVFQjQKUldTMFhvL3hwTEltUWVyeEVXOHZ2N3JLVnpmMk54K2NOelJsV21LelMrUStLa3lIMjIyVmlvT2MK",
      "endpoints": [
        "https://github.com/lovstudio/wxmp-cracker-app/releases/latest/download/latest.json"
      ]
    }
  }
}
